# Cyberpunk Agent - Development Environment Variables
# Copy this file to .env.local and fill in your actual paths

# FoundryVTT Modules Directory
# This is where the dev:copy script will copy your module files for testing
# 
# Common paths:
# Windows: C:\Users\YourUser\AppData\Local\FoundryVTT\Data\modules
# macOS: /Users/YourUser/Library/Application Support/FoundryVTT/Data/modules  
# Linux: /home/YourUser/.local/share/FoundryVTT/Data/modules
FOUNDRY_MODULES_PATH=

# FoundryVTT Application Path (for running Foundry locally)
# This is the path to the Foundry app resources folder
#
# Common paths:
# Windows: C:\Program Files\FoundryVTT\resources\app
# macOS: /Users/YourUser/Documents/FoundryVTT-12.343/resources/app
# Linux: /home/YourUser/foundryvtt/resources/app
FOUNDRY_APP_PATH=

# FoundryVTT Port (default: 30000)
FOUNDRY_APP_PORT=30000

# Optional: FoundryVTT Data Directory (if you need access to other FoundryVTT folders)
# FOUNDRY_DATA_PATH=

# Optional: Custom module name (defaults to 'cyberpunk-agent')
# MODULE_NAME=cyberpunk-agent

# Optional: Enable verbose logging during copy operations
# DEV_VERBOSE=true
